page { height: 100%; background: #f6f6f6; color: #151515; font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif; }
.my-page { height: 100vh; display: flex; flex-direction: column; overflow: hidden; }
.my-scroll { flex: 1; min-height: 0; }
.profile-header { position: relative; box-sizing: border-box; min-height: 510rpx; padding-left: 40rpx; padding-right: 40rpx; overflow: hidden; background: linear-gradient(135deg, #e9f0ff 0%, #e4ebfa 55%, #f4ecff 100%); }
.header-decoration { position: absolute; right: 54rpx; top: 180rpx; opacity: .13; }
.decoration-head { width: 112rpx; height: 72rpx; margin: auto; border-radius: 34rpx 34rpx 14rpx 14rpx; background: #91a9db; }
.decoration-body { width: 185rpx; height: 122rpx; margin-top: 12rpx; border-radius: 45% 45% 10rpx 10rpx; background: #91a9db; }
.settings { position: absolute; top: 95rpx; right: 205rpx; z-index: 2; font-size: 46rpx; }
.profile-row { display: flex; align-items: center; }
.avatar { width: 146rpx; height: 146rpx; flex: none; border: 4rpx solid #fff; border-radius: 50%; box-shadow: 0 2rpx 6rpx rgba(0,0,0,.15); }
.profile-info { margin-left: 24rpx; min-width: 0; }
.profile-name { display: block; max-width: 500rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: 30rpx; font-weight: 700; }
.level-chip { width: max-content; margin-top: 12rpx; padding: 4rpx 10rpx; color: #fff; border-radius: 7rpx; background: linear-gradient(90deg,#63c9ff,#1979df); font-size: 20rpx; }
.level-main { padding-right: 9rpx; border-right: 1rpx solid rgba(255,255,255,.8); }
.level-bean { font-weight: 600; }
.asset-row { margin-top: 42rpx; display: flex; justify-content: space-between; }
.asset-item { width: 25%; text-align: center; }
.asset-number { position: relative; height: 56rpx; white-space: nowrap; }
.asset-value { font-size: 46rpx; line-height: 56rpx; font-weight: 800; }
.asset-unit { margin-left: 5rpx; font-size: 22rpx; }
.asset-badge { position: absolute; left: 52%; top: -7rpx; padding: 3rpx 8rpx; color: #fff; border-radius: 15rpx 15rpx 15rpx 2rpx; background: #f36a48; font-size: 17rpx; }
.asset-title { display: block; margin-top: 3rpx; color: #3f4650; font-size: 23rpx; }
.panel-card { border-radius: 28rpx; background: #fff; box-shadow: 0 10rpx 28rpx rgba(28,42,64,.05); }
.overview-row { position: relative; z-index: 2; margin: -30rpx 24rpx 22rpx; display: flex; gap: 18rpx; }
.order-card { width: 61%; padding: 24rpx 26rpx; box-sizing: border-box; }
.service-card { flex: 1; padding: 24rpx 26rpx; box-sizing: border-box; }
.panel-title { display: block; font-size: 31rpx; font-weight: 700; }
.order-content { margin-top: 10rpx; display: flex; align-items: center; justify-content: space-between; }
.order-name { display: block; color: #163588; font-size: 25rpx; }
.order-again { display: block; width: max-content; margin-top: 12rpx; padding: 8rpx 24rpx; color: #fff; border-radius: 12rpx; background: #0c39ad; font-size: 23rpx; }
.order-image { width: 112rpx; height: 112rpx; border-radius: 0; }
.service-link { margin-top: 20rpx; color: #60646a; font-size: 24rpx; white-space: nowrap; }
.service-icon { display: inline-block; width: 45rpx; color: #222; font-size: 32rpx; }
.function-card { margin: 0 24rpx 22rpx; padding: 30rpx 28rpx 34rpx; }
.function-header { display: flex; align-items: center; justify-content: space-between; }
.expand { color: #6f7378; font-size: 24rpx; }
.function-list { margin-top: 32rpx; display: flex; justify-content: space-between; }
.function-item { width: 20%; display: flex; flex-direction: column; align-items: center; gap: 14rpx; color: #5c6066; font-size: 21rpx; white-space: nowrap; }
.function-icon { color: #34383d; font-size: 39rpx; line-height: 44rpx; }
.offer-row { margin: 0 24rpx 22rpx; display: flex; gap: 18rpx; }
.offer-card { position: relative; width: calc((100% - 18rpx)/2); height: 192rpx; box-sizing: border-box; padding: 28rpx 26rpx; overflow: hidden; border-radius: 25rpx; background: linear-gradient(135deg,#fff,#fbfcff); }
.offer-title { display: block; font-size: 28rpx; font-weight: 700; }
.offer-subtitle { display: block; margin-top: 8rpx; color: #676b73; font-size: 21rpx; }
.offer-button { position: absolute; left: 26rpx; bottom: 24rpx; padding: 8rpx 18rpx; color: #133a98; border: 2rpx solid #133a98; border-radius: 12rpx; font-size: 21rpx; }
.offer-art { position: absolute; right: 18rpx; bottom: 35rpx; font-weight: 800; transform: rotate(-8deg); }
.offer-art--ticket { padding: 10rpx; color: #e54b45; border: 4rpx solid #e54b45; background: #fff; font-size: 27rpx; }
.offer-art--cup { font-size: 45rpx; }
.member-banner { display: block; width: calc(100% - 48rpx); height: 186rpx; margin: 0 24rpx 22rpx; border-radius: 28rpx; background: #109fe8; }
.more-row { margin: 0 24rpx; display: flex; gap: 18rpx; }
.more-card { width: calc((100% - 18rpx)/2); height: 190rpx; box-sizing: border-box; padding: 30rpx; overflow: hidden; border-radius: 28rpx; background: #fff; }
.more-art { display: block; margin-top: 30rpx; text-align: center; font-size: 58rpx; }
.my-bottom-space { height: 28rpx; }
.my-bottom-tabs { flex: none; height: 118rpx; padding-bottom: env(safe-area-inset-bottom); display: flex; background: rgba(255,255,255,.97); border-top: 1rpx solid #ececec; box-shadow: 0 -4rpx 16rpx rgba(0,0,0,.04); }
.bottom-tab { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 3rpx; color: #8b939b; font-size: 21rpx; }
.bottom-tab-icon { height: 42rpx; font-size: 35rpx; line-height: 42rpx; font-weight: 700; }
.bottom-tab--active { color: #123b9c; }
