@import "../findOrder/findOrder.wxss";

.form-card {
  padding-bottom: 48rpx;
}

.photo-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  margin-top: 24rpx;
}

.photo-item {
  position: relative;
  min-width: 0;
  height: 210rpx;
}

.photo-image {
  width: 100%;
  height: 100%;
  border-radius: 6rpx;
  background: #ead8cc;
}

.delete-badge {
  position: absolute;
  right: -10rpx;
  top: -10rpx;
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  background: #c92a24;
  color: #ffffff;
  text-align: center;
  font-size: 30rpx;
  font-weight: 300;
  line-height: 34rpx;
  box-sizing: border-box;
}

.document-list {
  margin-top: 28rpx;
}

.document-row {
  position: relative;
  height: 112rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #eeeeee;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.document-icon {
  position: relative;
  width: 60rpx;
  height: 70rpx;
  margin: 0 28rpx 0 8rpx;
  border-radius: 5rpx;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-sizing: border-box;
  font-size: 34rpx;
  font-weight: 600;
}

.document-icon--pdf {
  background: #ef5350;
}

.document-icon--xls,
.document-icon--xlsx {
  background: #45be7b;
}

.document-fold {
  position: absolute;
  right: 0;
  top: 0;
  width: 18rpx;
  height: 18rpx;
  border-bottom-left-radius: 3rpx;
  background: rgba(255, 255, 255, 0.82);
}

.document-info {
  display: flex;
  flex: 1;
  min-width: 0;
  flex-direction: column;
  justify-content: center;
}

.document-name {
  color: #444444;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  font-size: 28rpx;
  line-height: 38rpx;
}

.document-size {
  color: #aaaaaa;
  font-size: 24rpx;
  line-height: 34rpx;
}

.document-delete {
  position: relative;
  top: auto;
  right: auto;
  margin-left: 24rpx;
  flex-shrink: 0;
}

.selected-store-panel {
  margin: -2rpx 0 28rpx;
  padding: 20rpx 18rpx 22rpx;
  border-radius: 6rpx;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  line-height: 42rpx;
}

.selected-store-title {
  color: #ef8b54;
  margin-bottom: 4rpx;
}

.selected-store-name {
  color: #444444;
}

.section-divider {
  margin-top: 30rpx;
}

.remark-section {
  padding-top: 36rpx;
}

.remark-input {
  height: 242rpx;
  padding-bottom: 22rpx;
}

.filled-submit-bar {
  border-top-width: 30rpx;
}

.filled-submit-bar .submit-button {
  background: #c92721;
}
