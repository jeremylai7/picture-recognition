<view wx:if="{{!indexShow}}">
  <view style="height: 100%;">
    <view class="img-view" wx:if="{{!showResult}}">
      <image src="/images/background.png" mode="heightFix"></image>
      <ad unit-id="adunit-53ceb16e96028fb1"></ad>
    </view>
    <view class="show-text-view" wx:else>
      <view class="page-section">
        <view class="page-section-title">文字结果</view>
        <view class="textarea-wrp" style="line-height:30px;">
          <textarea value="{{returnResult}}" maxlength="-1" auto-height />
        </view>
      </view>
    </view>

    <view class="btn-view">
      <button class="btn-upload" bindtap="doUpload">拍照/相册选取</button>
    </view>
  </view>
</view>

<view wx:else class="ip_find">
  <button open-type="share" class="share-btn" aria-label="分享">
    <view class="iconfont icon-fenxiang"></view>
  </button>

  <view wx:if="{{chatCount == 0}}" class="empty-chat">
    <view class="empty-hero">
      <view class="empty-badge">AI 智能问答</view>
      <view class="ip_find_text">今天想了解什么？</view>
      <view class="ip_find_remark">输入问题，AI 会帮你整理思路、提炼重点，也可以直接点下面的示例开始。</view>
    </view>

    <view class="quick-ask-grid">
      <view class="quick-ask-card" bindtap="copyDemo" data-text="帮我总结一下这段文字的重点">
        <view class="quick-ask-title">总结重点</view>
        <view class="quick-ask-desc">提炼长文本、会议内容或学习资料</view>
      </view>
      <view class="quick-ask-card" bindtap="copyDemo" data-text="帮我写一段简洁自然的文案">
        <view class="quick-ask-title">文案润色</view>
        <view class="quick-ask-desc">把想法改成更清楚的表达</view>
      </view>
      <view class="quick-ask-card" bindtap="copyDemo" data-text="给我一个三步解决方案">
        <view class="quick-ask-title">解决问题</view>
        <view class="quick-ask-desc">拆解问题，给出可执行步骤</view>
      </view>
      <view class="quick-ask-card" bindtap="copyDemo" data-text="用通俗的话解释这个概念">
        <view class="quick-ask-title">解释概念</view>
        <view class="quick-ask-desc">把复杂内容讲得更好懂</view>
      </view>
    </view>

    <view class="empty-tips">
      <view class="tip-item">支持学习、工作、生活里的开放问题</view>
      <view class="tip-item">示例会自动填入输入框，发送前仍可修改</view>
    </view>
  </view>

  <view wx:else class="chat-layout">
    <view id="ask-text" class="ask-text">
      <view class="ip_find_text">智能 AI 回答</view>
      <view class="ip_find_remark">发送你想说的话，AI 会告诉你答案。</view>
    </view>
    <scroll-view scroll-top="{{headScrollTop}}" class="chat-frame" scroll-y="true">
      <view class="chat-content">
        <view wx:for="{{chatArray}}" wx:key="unique" class="{{item.type == 1 ? 'result-view-right' : 'result-view-left'}}">
          <view wx:if="{{item.type == 2}}" class="result-title">
            <view class="title-result"></view>
            <view class="title-copy" data-message="{{item.message}}" bindtap="copyResult">
              <view class="iconfont icon-fuzhi"></view>
              <view>复制</view>
            </view>
          </view>
          <scroll-view scroll-y="true" scroll-top="{{scrollTop}}" class="result-card">
            <view class="content-info">
              <towxml nodes="{{item.messageMarkdown}}" />
            </view>
          </scroll-view>
        </view>
      </view>
    </scroll-view>
  </view>
</view>

<view wx:if="{{indexShow}}" class="botton-input">
  <view class="botton-input-view">
    <input class="ip_input" type="text" value="{{searchText}}" placeholder="问点什么..." placeholder-class="input-text" bindinput="changeText" bindconfirm="onConfirm" />
    <view bindtap="chatAnswer" class="send_icon_wrap">
      <view class="iconfont icon-fasong send_icon"></view>
    </view>
  </view>
</view>
