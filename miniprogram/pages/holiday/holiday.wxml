<view class="holiday-page">
  <view class="hero-card">
    <view class="hero-kicker">HOLIDAY COUNTDOWN</view>
    <view class="hero-row">
      <view>
        <view class="hero-title">节假日倒计时</view>
        <view class="time-value">{{nowTime}}</view>
      </view>
      <view class="week-pill">周{{week}}</view>
    </view>
  </view>

  <view class="notice-card">
    <view class="section-title">今日提醒</view>
    <view class="notice-text">
      <text class="notice-strong">【摸鱼办】</text>{{month}}月{{date}}日{{intervalTime}}好。工作再忙，也要记得休息、走动、喝水，顺便完成今天的工作。
    </view>
  </view>

  <view class="countdown-card">
    <view class="section-head">
      <view class="section-title">假期距离</view>
      <view class="section-note">盼头清单</view>
    </view>
    <view class="holiday-grid">
      <view wx:for="{{DomArray}}" wx:key="unique" class="holiday-item">
        <view class="holiday-dot"></view>
        <view class="holiday-text">{{item}}</view>
      </view>
    </view>
  </view>
</view>
