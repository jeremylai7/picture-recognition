page {
  min-height: 100%;
  background: #f4f4f4;
  color: #222222;
}

.coffee-page {
  width: 100%;
  overflow-x: hidden;
}

.hero {
  position: relative;
  height: 530rpx;
  overflow: hidden;
  background: #102d69;
}

.hero-image,
.hero-shade {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
}

.hero-shade {
  background: linear-gradient(90deg, rgba(12, 38, 90, 0.02) 40%, rgba(7, 27, 68, 0.25) 100%);
}

.hero-tools {
  position: absolute;
  z-index: 3;
  left: 28rpx;
  right: 28rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.scan-button {
  position: relative;
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.2);
  backdrop-filter: blur(4rpx);
}

.scan-corner {
  position: absolute;
  width: 17rpx;
  height: 17rpx;
  border-color: #ffffff;
  border-style: solid;
}

.scan-corner--tl { left: 14rpx; top: 14rpx; border-width: 3rpx 0 0 3rpx; }
.scan-corner--tr { right: 14rpx; top: 14rpx; border-width: 3rpx 3rpx 0 0; }
.scan-corner--bl { left: 14rpx; bottom: 14rpx; border-width: 0 0 3rpx 3rpx; }
.scan-corner--br { right: 14rpx; bottom: 14rpx; border-width: 0 3rpx 3rpx 0; }

.tool-active,
.card-active {
  opacity: 0.82;
}

.hero-copy {
  position: absolute;
  z-index: 2;
  right: 34rpx;
  top: 212rpx;
  width: 320rpx;
  color: #ffffff;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.hero-eyebrow {
  padding-bottom: 10rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.45);
  font-size: 18rpx;
  letter-spacing: 2rpx;
}

.hero-title {
  margin-top: 18rpx;
  font-size: 38rpx;
  font-weight: 700;
  font-style: italic;
  line-height: 52rpx;
}

.hero-subtitle {
  margin-top: 4rpx;
  font-size: 23rpx;
}

.hero-cta {
  margin-top: 18rpx;
  padding: 10rpx 26rpx;
  border-radius: 28rpx;
  background: #e52127;
  font-size: 22rpx;
}

.hero-cta--active {
  transform: scale(0.96);
}

.hero-pagination {
  position: absolute;
  z-index: 2;
  left: 50%;
  bottom: 78rpx;
  display: flex;
  gap: 16rpx;
  transform: translateX(-50%);
}

.page-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.55);
}

.page-dot--active {
  width: 36rpx;
  border-radius: 6rpx;
  background: #ffffff;
}

.member-bar {
  position: relative;
  z-index: 4;
  height: 76rpx;
  margin: -58rpx 26rpx 0;
  padding: 0 26rpx;
  border-radius: 18rpx 18rpx 0 0;
  background: linear-gradient(90deg, #23282e, #303238);
  color: #d7b76c;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.member-avatar {
  width: 48rpx;
  height: 48rpx;
  margin-right: 18rpx;
  border-radius: 50%;
  background: #805b42;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.member-greeting {
  flex: 1;
  font-size: 24rpx;
  font-weight: 500;
}

.member-level {
  font-size: 22rpx;
}

.service-card {
  margin: 0 26rpx 22rpx;
  padding: 34rpx 20rpx 30rpx;
  border-radius: 0 0 18rpx 18rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
}

.primary-services,
.secondary-services {
  display: flex;
}

.primary-services {
  justify-content: space-around;
}

.secondary-services {
  margin-top: 36rpx;
  justify-content: space-between;
}

.service-item {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.service-item--primary {
  width: 31%;
}

.service-item--secondary {
  width: 24%;
}

.primary-icon {
  width: 84rpx;
  height: 74rpx;
  border-radius: 28rpx 28rpx 16rpx 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 46rpx;
}

.icon-pickup { background: #d9efff; }
.icon-delivery { background: #e5efff; }
.icon-coffee { background: #d7e6ff; }

.service-title {
  margin-top: 14rpx;
  color: #222222;
  font-size: 29rpx;
  font-weight: 600;
}

.service-subtitle {
  margin-top: 7rpx;
  color: #999999;
  font-size: 20rpx;
}

.secondary-icon {
  height: 54rpx;
  color: #333333;
  font-size: 44rpx;
  line-height: 54rpx;
}

.service-badge {
  position: absolute;
  right: 3rpx;
  top: -14rpx;
  padding: 3rpx 9rpx;
  border-radius: 16rpx 16rpx 16rpx 0;
  background: #eb4a36;
  color: #ffffff;
  font-size: 16rpx;
}

.secondary-title {
  margin-top: 10rpx;
  color: #333333;
  font-size: 24rpx;
}

.secondary-subtitle {
  margin-top: 5rpx;
  color: #aaaaaa;
  font-size: 18rpx;
  white-space: nowrap;
}

.promotion-grid {
  margin: 0 26rpx 22rpx;
  display: flex;
  gap: 18rpx;
}

.promotion-card {
  position: relative;
  border-radius: 16rpx;
  background: #ffffff;
  overflow: hidden;
  box-sizing: border-box;
}

.promotion-card--large {
  width: 50%;
  height: 286rpx;
  padding: 28rpx 18rpx;
}

.promotion-content {
  position: relative;
  z-index: 2;
}

.price-major {
  color: #c70f19;
  font-size: 48rpx;
  font-weight: 700;
}

.price-unit {
  margin-left: 6rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.promotion-subtitle,
.small-promo-subtitle {
  display: block;
  color: #777777;
  font-size: 20rpx;
}

.red-pill {
  width: 120rpx;
  height: 42rpx;
  margin-top: 18rpx;
  border-radius: 23rpx;
  background: #cf0d1a;
  color: #ffffff;
  text-align: center;
  font-size: 20rpx;
  line-height: 42rpx;
}

.promo-mascot {
  position: absolute;
  right: -60rpx;
  bottom: -40rpx;
  width: 260rpx;
  height: 190rpx;
  border-radius: 50%;
}

.promotion-column {
  width: 50%;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.promotion-card--small {
  height: 134rpx;
  padding: 20rpx 14rpx;
}

.small-promo-copy {
  position: relative;
  z-index: 2;
  width: 75%;
  display: flex;
  flex-direction: column;
}

.small-promo-title {
  font-size: 23rpx;
  font-weight: 600;
  white-space: nowrap;
}

.small-promo-subtitle {
  margin-top: 6rpx;
}

.buy-now {
  margin-top: 8rpx;
  font-size: 20rpx;
}

.red-text {
  color: #c70f19;
}

.drink-art {
  position: absolute;
  right: 12rpx;
  bottom: 12rpx;
  width: 66rpx;
  height: 86rpx;
  border-radius: 8rpx 8rpx 20rpx 20rpx;
  background: linear-gradient(#e7d4b0, #613d2a);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.drink-art--orange {
  background: linear-gradient(#451e16, #f5a324);
  color: #ffffff;
}

.orange-card {
  background: linear-gradient(100deg, #ffffff 65%, #fff4dc);
}

.recommend-section {
  margin: 0 26rpx;
  padding: 24rpx 24rpx 30rpx;
  border-radius: 16rpx;
  background: #ffffff;
}

.recommend-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.recommend-title {
  font-size: 34rpx;
  font-weight: 600;
}

.recommend-brand {
  color: #173b80;
  font-size: 18rpx;
  font-weight: 600;
}

.recommend-list {
  display: flex;
  gap: 18rpx;
  margin-top: 24rpx;
}

.coffee-product {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.product-cup {
  width: 100%;
  height: 130rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 54rpx;
}

.cup-blue { background: #e6efff; }
.cup-orange { background: #fff0d9; }
.cup-brown { background: #f0e4dc; }

.product-name {
  margin-top: 12rpx;
  font-size: 22rpx;
}

.product-price {
  margin-top: 5rpx;
  color: #c70f19;
  font-size: 22rpx;
  font-weight: 600;
}

.tab-spacer {
  height: calc(120rpx + env(safe-area-inset-bottom));
}

.bottom-tabs {
  position: fixed;
  z-index: 20;
  left: 0;
  right: 0;
  bottom: 0;
  height: calc(112rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  border-top: 1rpx solid #eeeeee;
  background: rgba(255, 255, 255, 0.97);
  display: flex;
  box-sizing: border-box;
}

.tab-item {
  width: 20%;
  color: #7f8790;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 21rpx;
}

.tab-icon {
  height: 48rpx;
  margin-bottom: 4rpx;
  font-size: 34rpx;
  line-height: 48rpx;
}

.tab-item--active {
  color: #173d86;
  font-weight: 600;
}
