page {
  height: 100%;
  background: #f5f5f5;
  color: #242424;
}

.menu-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.menu-header {
  flex: none;
  background: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.top-row,
.store-row {
  padding: 0 26rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.top-row {
  height: 92rpx;
}

.service-switch {
  display: flex;
  align-items: center;
}

.service-mode {
  position: relative;
  padding: 0 18rpx;
  color: #a4a4a4;
  font-size: 30rpx;
  line-height: 50rpx;
}

.service-mode:first-child {
  padding-left: 0;
}

.service-mode + .service-mode::before {
  position: absolute;
  left: 0;
  top: 13rpx;
  width: 1rpx;
  height: 24rpx;
  background: #dddddd;
  content: '';
}

.service-mode--active {
  color: #202020;
  font-size: 36rpx;
  font-weight: 700;
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.search-button,
.more-button {
  width: 64rpx;
  height: 64rpx;
  border: 1rpx solid #eeeeee;
  border-radius: 50%;
  background: #ffffff;
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.05);
  box-sizing: border-box;
}

.search-button {
  position: relative;
}

.search-button::before {
  position: absolute;
  left: 18rpx;
  top: 15rpx;
  width: 22rpx;
  height: 22rpx;
  border: 4rpx solid #222222;
  border-radius: 50%;
  content: '';
}

.search-button::after {
  position: absolute;
  right: 13rpx;
  bottom: 14rpx;
  width: 17rpx;
  height: 4rpx;
  border-radius: 2rpx;
  background: #222222;
  transform: rotate(45deg);
  content: '';
}

.more-button {
  width: 92rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 56rpx;
}

.store-row {
  height: 78rpx;
}

.store-location {
  font-size: 26rpx;
  font-weight: 600;
}

.location-icon {
  margin-right: 10rpx;
  color: #183d8d;
  font-size: 20rpx;
}

.distance {
  margin-left: 8rpx;
  color: #777777;
  font-size: 22rpx;
  font-weight: 400;
}

.group-order {
  padding: 12rpx 20rpx;
  border-radius: 30rpx;
  background: #f8f8f8;
  font-size: 24rpx;
}

.coupon-scroll {
  width: 100%;
  white-space: nowrap;
}

.coupon-list {
  padding: 8rpx 24rpx 18rpx;
  display: inline-flex;
  gap: 12rpx;
}

.coupon {
  padding: 13rpx 18rpx;
  border-radius: 6rpx;
  background: linear-gradient(90deg, #fff4ef, #fff9f5);
  color: #d8563c;
  font-size: 21rpx;
}

.menu-tabs {
  height: 86rpx;
  display: flex;
}

.menu-tab {
  position: relative;
  width: 33.333%;
  color: #666666;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 27rpx;
}

.menu-tab-line {
  position: absolute;
  left: 50%;
  bottom: 0;
  width: 48rpx;
  height: 6rpx;
  border-radius: 4rpx;
  background: transparent;
  transform: translateX(-50%);
}

.menu-tab--active {
  color: #222222;
  font-weight: 700;
}

.menu-tab--active .menu-tab-line {
  background: #1643a0;
}

.menu-content {
  min-height: 0;
  flex: 1;
  display: flex;
  background: #f5f5f5;
}

.category-scroll {
  width: 166rpx;
  height: 100%;
  flex: none;
  background: #f1f1f1;
}

.category-item {
  position: relative;
  min-height: 98rpx;
  padding: 15rpx 10rpx 15rpx 28rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  box-sizing: border-box;
}

.category-item--active {
  background: #ffffff;
  font-weight: 700;
}

.category-marker {
  position: absolute;
  left: 0;
  top: 20rpx;
  bottom: 20rpx;
  width: 7rpx;
  border-radius: 0 5rpx 5rpx 0;
  background: transparent;
}

.category-item--active .category-marker {
  background: #1648b0;
}

.category-icon {
  font-size: 36rpx;
  line-height: 40rpx;
}

.category-badge {
  margin-bottom: 5rpx;
  padding: 2rpx 8rpx;
  border-radius: 11rpx 11rpx 11rpx 0;
  background: #b49a6a;
  color: #ffffff;
  font-size: 16rpx;
}

.category-title {
  font-size: 23rpx;
  line-height: 30rpx;
}

.product-scroll {
  min-width: 0;
  height: 100%;
  flex: 1;
  background: #ffffff;
}

.product-heading {
  padding: 24rpx 26rpx 12rpx;
  display: flex;
  flex-direction: column;
}

.product-heading-title {
  font-size: 31rpx;
  font-weight: 700;
}

.product-heading-subtitle {
  margin-top: 5rpx;
  color: #aaaaaa;
  font-size: 20rpx;
}

.drink-card {
  min-height: 250rpx;
  padding: 16rpx 22rpx;
  display: flex;
  box-sizing: border-box;
}

.drink-image {
  width: 168rpx;
  height: 168rpx;
  margin-top: 8rpx;
  flex: none;
  border-radius: 50%;
  background: #f3f3f3;
}

.drink-info {
  min-width: 0;
  margin-left: 20rpx;
  flex: 1;
}

.drink-name {
  max-width: 100%;
  display: block;
  overflow: hidden;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 40rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.drink-badges {
  height: 36rpx;
  margin-top: 8rpx;
  display: flex;
  gap: 7rpx;
  overflow: hidden;
}

.drink-badge {
  padding: 3rpx 7rpx;
  border: 1rpx solid #eadfce;
  color: #aa8a60;
  font-size: 16rpx;
  white-space: nowrap;
}

.drink-description {
  margin-top: 8rpx;
  color: #999999;
  display: block;
  overflow: hidden;
  font-size: 20rpx;
  line-height: 28rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.drink-buy-row {
  margin-top: 18rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}

.drink-price-wrap {
  display: flex;
  align-items: baseline;
}

.drink-price {
  color: #e44a2e;
  font-size: 32rpx;
  font-weight: 700;
}

.drink-yen {
  margin-right: 3rpx;
  font-size: 21rpx;
}

.drink-original-price {
  margin-left: 7rpx;
  color: #a0a0a0;
  font-size: 19rpx;
  text-decoration: line-through;
}

.select-button {
  padding: 10rpx 21rpx;
  border-radius: 28rpx;
  background: #073b9f;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 600;
}

.product-bottom-space {
  height: 40rpx;
}

.menu-bottom-tabs {
  flex: none;
  height: calc(108rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  border-top: 1rpx solid #eeeeee;
  background: rgba(255, 255, 255, 0.98);
  display: flex;
  box-sizing: border-box;
}

.bottom-tab {
  width: 20%;
  color: #8f969c;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
}

.bottom-tab-icon {
  height: 42rpx;
  margin-bottom: 3rpx;
  font-size: 32rpx;
  line-height: 42rpx;
}

.bottom-tab--active {
  color: #153f96;
  font-weight: 700;
}
