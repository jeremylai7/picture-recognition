page {
  height: 100%;
  background: #f5f5f5;
  color: #161616;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
}

.enjoy-page { height: 100vh; display: flex; flex-direction: column; overflow: hidden; }
.enjoy-header { flex: none; height: 88rpx; box-sizing: content-box; display: flex; align-items: center; justify-content: center; background: #f7f7f7; }
.enjoy-title { font-size: 34rpx; line-height: 88rpx; font-weight: 700; }
.enjoy-scroll { flex: 1; min-height: 0; }
.hero-scroll { width: 100%; white-space: nowrap; }
.hero-list { display: inline-flex; gap: 12rpx; padding: 0 20rpx; }
.hero-card { width: calc((100vw - 52rpx) / 2); height: 330rpx; flex: none; border-radius: 16rpx; background: #fff; }
.hero-dots { height: 34rpx; display: flex; align-items: center; justify-content: center; gap: 10rpx; }
.hero-dot { width: 10rpx; height: 10rpx; border-radius: 50%; background: #d3d3d3; }
.hero-dot--active { background: #9b9b9b; }

.category-panel { margin: 0 20rpx 20rpx; padding: 28rpx 12rpx 24rpx; display: flex; justify-content: space-between; border-radius: 14rpx; background: #fff; }
.category-item { width: 20%; display: flex; flex-direction: column; align-items: center; }
.category-image-wrap { position: relative; width: 110rpx; height: 92rpx; }
.category-image { width: 100%; height: 100%; border-radius: 6rpx; background: #f7f7f7; }
.category-badge { position: absolute; top: -15rpx; right: 2rpx; padding: 2rpx 8rpx; color: #fff; background: #15398d; border-radius: 6rpx; font-size: 18rpx; }
.category-title { margin-top: 12rpx; font-size: 25rpx; white-space: nowrap; }

.campaign-row { margin: 0 20rpx 20rpx; display: flex; gap: 12rpx; }
.campaign-card { width: calc((100% - 12rpx) / 2); height: 230rpx; border-radius: 12rpx; background: #fff; }
.product-grid { padding: 0 20rpx; display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 14rpx; }
.product-card { min-width: 0; overflow: hidden; border-radius: 12rpx; background: #fff; }
.product-image { width: 100%; height: 330rpx; background: #f2f2f2; }
.product-content { padding: 16rpx 18rpx 20rpx; }
.product-title { height: 82rpx; display: -webkit-box; overflow: hidden; -webkit-box-orient: vertical; -webkit-line-clamp: 2; font-size: 27rpx; line-height: 41rpx; font-weight: 500; }
.product-tags { min-height: 42rpx; margin-top: 8rpx; display: flex; flex-wrap: wrap; gap: 7rpx; }
.product-tag { padding: 3rpx 8rpx; color: #e66c54; background: #fff0eb; border-radius: 3rpx; font-size: 20rpx; }
.product-price-row { margin-top: 8rpx; display: flex; align-items: baseline; gap: 10rpx; color: #e84f35; }
.product-price-label { font-size: 23rpx; }
.product-price { font-size: 39rpx; font-weight: 700; }
.product-yen { margin-right: 3rpx; font-size: 25rpx; }
.product-sold { display: block; margin-top: 18rpx; color: #9c9c9c; font-size: 22rpx; }
.page-bottom-space { height: 30rpx; }

.enjoy-bottom-tabs { flex: none; height: 118rpx; padding-bottom: env(safe-area-inset-bottom); display: flex; background: rgba(255,255,255,.97); border-top: 1rpx solid #ececec; box-shadow: 0 -4rpx 16rpx rgba(0,0,0,.04); }
.bottom-tab { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 3rpx; color: #8b939b; font-size: 21rpx; }
.bottom-tab-icon { height: 42rpx; font-size: 35rpx; line-height: 42rpx; font-weight: 700; }
.bottom-tab--active { color: #123b9c; }
