<view class="recognize-page">
  <view class="recognize-hero">
    <view class="hero-copy">
      <view class="hero-kicker">OCR IMAGE RECOGNITION</view>
      <view class="hero-title">图片文字识别</view>
      <view class="hero-desc">拍照或从相册选择图片，快速提取图片中的文字内容。</view>
    </view>
    <view class="hero-visual">
      <image src="/images/background.png" mode="aspectFill"></image>
    </view>
  </view>

  <view class="feature-row">
    <view class="feature-item">
      <view class="feature-icon">快</view>
      <view class="feature-text">快速识别</view>
    </view>
    <view class="feature-item">
      <view class="feature-icon">准</view>
      <view class="feature-text">清晰提取</view>
    </view>
    <view class="feature-item">
      <view class="feature-icon">便</view>
      <view class="feature-text">一键复制</view>
    </view>
  </view>

  <view class="recognize-card" wx:if="{{!showResult}}">
    <view class="upload-illustration">
      <view class="scan-frame">
        <view class="scan-line"></view>
      </view>
    </view>
    <view class="upload-title">选择一张包含文字的图片</view>
    <view class="upload-desc">支持拍照、截图、票据、书页和海报等常见图片。</view>
    <view class="ad-shell">
      <ad unit-id="adunit-53ceb16e96028fb1"></ad>
    </view>
  </view>

  <view class="result-panel" wx:else>
    <view class="result-header">
      <view>
        <view class="result-title">识别结果</view>
        <view class="result-subtitle">可直接长按选择文字，继续编辑或复制。</view>
      </view>
      <view class="result-badge">TEXT</view>
    </view>
    <view class="textarea-wrp">
      <textarea value="{{returnResult}}" maxlength="-1" auto-height />
    </view>
  </view>

  <view class="btn-view">
    <button class="btn-upload" bindtap="doUpload">拍照 / 相册选取</button>
  </view>
</view>

