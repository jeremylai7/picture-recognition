page {
  min-height: 100%;
  background: #f5f5f5;
  color: #666666;
  font-size: 30rpx;
}

.page {
  width: 100%;
}

.step-banner {
  height: 562.5rpx;
  background: #c6c6c6;
  color: #3f3f3f;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  font-size: 32rpx;
  line-height: 1.5;
}

.ratio-tip {
  margin-top: 20rpx;
}

.form-card {
  padding: 80rpx 22rpx 50rpx;
  background: #ffffff;
  box-sizing: border-box;
}

.upload-heading {
  display: flex;
  align-items: center;
  line-height: 44rpx;
}

.required {
  color: #d93025;
}

.upload-description {
  margin-top: 8rpx;
  line-height: 42rpx;
}

.upload-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 26rpx;
}

.upload-button {
  width: 210rpx;
  height: 210rpx;
  border-radius: 8rpx;
  background: #f6f6f6;
  color: #999999;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.upload-button--active,
.row--active {
  background: #eeeeee;
}

.upload-icon {
  position: relative;
  width: 54rpx;
  height: 54rpx;
  margin-bottom: 16rpx;
  box-sizing: border-box;
  color: #a2a2a2;
}

.picture-icon {
  border: 4rpx solid #a2a2a2;
  border-radius: 4rpx;
  margin-top: 6rpx;
}

.picture-mountain {
  position: absolute;
  left: 9rpx;
  bottom: 8rpx;
  width: 27rpx;
  height: 18rpx;
  border-left: 4rpx solid #a2a2a2;
  border-top: 4rpx solid #a2a2a2;
  transform: rotate(45deg) skew(-10deg, -10deg);
}

.icon-plus {
  position: absolute;
  right: -14rpx;
  top: -25rpx;
  padding: 2rpx;
  background: #f6f6f6;
  font-size: 34rpx;
  font-weight: 600;
  line-height: 34rpx;
}

.file-icon {
  border: 4rpx solid #a2a2a2;
  border-radius: 3rpx;
}

.file-fold {
  position: absolute;
  right: -4rpx;
  top: -4rpx;
  width: 15rpx;
  height: 15rpx;
  background: #f6f6f6;
  border-left: 4rpx solid #a2a2a2;
  border-bottom: 4rpx solid #a2a2a2;
}

.file-plus {
  position: absolute;
  left: 13rpx;
  top: 5rpx;
  font-size: 36rpx;
  line-height: 36rpx;
}

.attachment-list {
  margin-top: 26rpx;
}

.attachment-item {
  min-height: 82rpx;
  padding: 10rpx 8rpx;
  border-top: 1rpx solid #eeeeee;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.attachment-thumb,
.attachment-file {
  width: 62rpx;
  height: 62rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
}

.attachment-file {
  background: #f0f0f0;
  color: #999999;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  text-transform: uppercase;
}

.attachment-name {
  flex: 1;
  min-width: 0;
  margin: 0 20rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  font-size: 26rpx;
}

.remove-attachment {
  width: 52rpx;
  height: 52rpx;
  line-height: 48rpx;
  text-align: center;
  color: #999999;
  font-size: 38rpx;
}

.divider {
  height: 1rpx;
  background: #e8e8e8;
}

.upload-actions + .divider,
.attachment-list + .divider {
  margin-top: 32rpx;
}

.store-row,
.info-row {
  min-height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.store-value {
  display: flex;
  align-items: center;
}

.placeholder {
  color: #aaaaaa;
}

.selected-value,
.info-value {
  color: #333333;
}

.chevron {
  width: 17rpx;
  height: 17rpx;
  margin: 0 10rpx 0 24rpx;
  border-top: 3rpx solid #999999;
  border-right: 3rpx solid #999999;
  transform: rotate(45deg);
}

.remark-section {
  padding: 40rpx 0 34rpx;
}

.field-label {
  display: block;
  margin-bottom: 28rpx;
}

.textarea-wrap {
  position: relative;
}

.remark-input {
  width: 100%;
  height: 242rpx;
  padding: 22rpx 18rpx 50rpx;
  border-radius: 8rpx;
  background: #f6f6f6;
  color: #333333;
  font-size: 28rpx;
  line-height: 42rpx;
  box-sizing: border-box;
}

.remark-placeholder {
  color: #aaaaaa;
}

.remark-count {
  position: absolute;
  right: 18rpx;
  bottom: 14rpx;
  color: #aaaaaa;
  font-size: 22rpx;
}

.info-row {
  font-size: 30rpx;
}

.info-value {
  margin-right: 2rpx;
  font-weight: 500;
}

.bottom-spacer {
  height: calc(150rpx + env(safe-area-inset-bottom));
}

.submit-bar {
  position: fixed;
  z-index: 10;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 22rpx calc(20rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 22rpx solid #f5f5f5;
  box-sizing: border-box;
}

.submit-button {
  width: 100%;
  height: 86rpx;
  margin: 0;
  padding: 0;
  border-radius: 8rpx;
  background: #dc918d;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 500;
  line-height: 86rpx;
}

.submit-button[disabled] {
  background: #e7aaa7;
  color: #ffffff;
}

.store-selector {
  height: 100%;
  background: #ffffff;
  color: #444444;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.selector-header {
  position: relative;
  height: 112rpx;
  border-bottom: 1rpx solid #eeeeee;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-sizing: border-box;
}

.selector-title {
  color: #333333;
  font-size: 32rpx;
  font-weight: 600;
}

.selector-close {
  position: absolute;
  right: 18rpx;
  top: 22rpx;
  width: 68rpx;
  height: 68rpx;
}

.selector-close--active {
  opacity: 0.5;
}

.close-line {
  position: absolute;
  left: 21rpx;
  top: 32rpx;
  width: 30rpx;
  height: 3rpx;
  border-radius: 2rpx;
  background: #333333;
}

.close-line--left {
  transform: rotate(45deg);
}

.close-line--right {
  transform: rotate(-45deg);
}

.store-list {
  flex: 1;
  min-height: 0;
  padding-left: 22rpx;
  box-sizing: border-box;
}

.store-option {
  height: 106rpx;
  padding-right: 24rpx;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.store-option--active {
  background: #f8f8f8;
}

.check-circle {
  position: relative;
  width: 38rpx;
  height: 38rpx;
  margin-right: 20rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 50%;
  flex-shrink: 0;
  box-sizing: border-box;
}

.check-circle--selected {
  border-color: #c92a24;
  background: #c92a24;
}

.check-mark {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
}

.check-stroke {
  position: absolute;
  height: 3rpx;
  border-radius: 3rpx;
  background: #ffffff;
  transform-origin: left center;
}

.check-stroke--short {
  left: 9rpx;
  top: 17rpx;
  width: 10rpx;
  transform: rotate(45deg);
}

.check-stroke--long {
  left: 15rpx;
  top: 24rpx;
  width: 18rpx;
  transform: rotate(-48deg);
}

.store-name {
  height: 106rpx;
  border-bottom: 1rpx solid #eeeeee;
  color: #444444;
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  white-space: nowrap;
}

.selector-footer {
  min-height: 126rpx;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #eeeeee;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-shrink: 0;
  box-sizing: border-box;
  font-size: 28rpx;
  line-height: 84rpx;
}

.confirm-store-button {
  width: 226rpx;
  height: 84rpx;
  margin-left: auto;
  flex-shrink: 0;
  border-radius: 7rpx;
  background: #c92721;
  color: #ffffff;
  text-align: center;
  font-size: 30rpx;
  line-height: 84rpx;
  box-sizing: border-box;
}

.confirm-store-button--active {
  background: #b9231e;
}
